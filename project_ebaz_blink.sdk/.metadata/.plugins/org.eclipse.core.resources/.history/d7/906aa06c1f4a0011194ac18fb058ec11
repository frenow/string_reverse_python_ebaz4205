#include <stdio.h>
#include "platform.h"
#include "xil_printf.h"
#include "xuartps.h" // Driver da UART do Zynq

int main() {
    init_platform();

    print("--- EBAZ4205 Serial Test ---\n\r");
    print("Digite algo para ver o eco:\n\r");

    while(1) {
        // Recebe um caractere via UART
        char c = inbyte();

        // Envia de volta (Eco)
        print("Recebido: ");
        outbyte(c);
        print("\n\r");

        // Se digitar 'r', podemos sinalizar algo
        if(c == 'r') print("Comando RESET detectado!\n\r");
    }

    cleanup_platform();
    return 0;
}
